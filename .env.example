# Server-side environment variables for Vercel deployment

# Database Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database-name?retryWrites=true&w=majority
MONGODB_DB=Shop

# JWT Configuration
JWT_SECRET=your-super-secret-key-here-change-this-in-production

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
ADMIN_EMAIL=admin@somikoron.com

# SSLCommerz Payment Gateway
SSLCOMMERZ_STORE_ID=your-sslcommerz-store-id
SSLCOMMERZ_STORE_PASSWORD=your-sslcommerz-store-password
SSLCOMMERZ_IS_LIVE=false
SSLCOMMERZ_SUCCESS_URL=https://somikoron-shop.vercel.app/payment/success
SSLCOMMERZ_FAIL_URL=https://somikoron-shop.vercel.app/payment/fail
SSLCOMMERZ_CANCEL_URL=https://somikoron-shop.vercel.app/payment/cancel

# Environment
NODE_ENV=production

# CORS Settings
ALLOWED_ORIGINS=https://somikoron-shop.vercel.app,https://localhost:3000

# Default Admin Credentials (for initial setup)
ADMIN_EMAIL=admin@somikoron.com
ADMIN_PASSWORD=admin123

# Test Payment Cards:
# Visa: 4242424242424242
# Mastercard: 5555555555554444
# Any Expiry: Future date
# CVV: 123
